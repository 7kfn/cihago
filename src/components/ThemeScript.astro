---
// Pre-paint script: applies a stored theme override before first paint
// to avoid a flash, then keeps <meta name="theme-color"> in sync.
// Valid values: "light" | "dark" | "auto" (auto is represented by no attribute).
---
<script is:inline>
  (function () {
    var KEY = 'cihago-theme';
    var COLORS = { light: '#fafafa', dark: '#111111' };

    function systemPref() {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function applyTheme(mode) {
      var root = document.documentElement;
      if (mode === 'light' || mode === 'dark') {
        root.setAttribute('data-theme', mode);
      } else {
        root.removeAttribute('data-theme');
      }
      var effective = (mode === 'light' || mode === 'dark') ? mode : systemPref();
      var meta = document.getElementById('meta-theme-color');
      if (meta) meta.setAttribute('content', COLORS[effective]);
    }

    var stored;
    try { stored = localStorage.getItem(KEY); } catch (e) {}
    var initial = (stored === 'light' || stored === 'dark') ? stored : 'auto';
    applyTheme(initial);

    // React to OS-level changes when in auto mode.
    try {
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () {
        var s;
        try { s = localStorage.getItem(KEY); } catch (e) {}
        if (s !== 'light' && s !== 'dark') applyTheme('auto');
      });
    } catch (e) {}

    // Public API for the toggle component.
    window.__cihagoTheme = {
      get: function () {
        var s;
        try { s = localStorage.getItem(KEY); } catch (e) {}
        return (s === 'light' || s === 'dark') ? s : 'auto';
      },
      set: function (mode) {
        try {
          if (mode === 'auto') localStorage.removeItem(KEY);
          else localStorage.setItem(KEY, mode);
        } catch (e) {}
        applyTheme(mode);
        window.dispatchEvent(new CustomEvent('cihago:theme-change', { detail: mode }));
      },
    };
  })();
</script>
