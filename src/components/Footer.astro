---
import { SITE_TITLE, SITE_TAGLINE } from '../consts';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="wrap">
    <p class="site-footer__line">
      {SITE_TITLE} &middot; {SITE_TAGLINE} &middot; &copy; {year}
    </p>
    <p class="site-footer__credit">
      Set in <a href="https://github.com/iaolo/iA-Fonts" target="_blank" rel="noopener noreferrer">iA Writer Quattro</a>,
      a fork of <a href="https://www.ibm.com/plex/" target="_blank" rel="noopener noreferrer">IBM Plex</a>.
    </p>
  </div>
</footer>
