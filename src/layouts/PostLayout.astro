---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout title={title} description={description} ogType="article" publishedTime={pubDate}>
  <article class="post" data-pagefind-body>
    <header>
      <h1>{title}</h1>
      <p class="meta">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {updatedDate && <> · updated <time datetime={updatedDate.toISOString()}>{fmt(updatedDate)}</time></>}
      </p>
      {tags.length > 0 && (
        <p class="tags">
          {tags.map((tag) => (
            <a href={`/tags/${tag}/`} class="tag">{tag}</a>
          ))}
        </p>
      )}
    </header>
    <slot />
    {/* Comments will live here in future. Recommended: Cusdis (anonymous-friendly). */}
  </article>
  <p class="post-back"><a href="/">&larr; All posts</a></p>
</BaseLayout>
